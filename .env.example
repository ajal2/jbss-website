# Copy to .env.local and fill in. Notion + careers config for the site.

# Notion integration token (Settings → Connections → your internal integration)
NOTION_API_KEY=ntn_xxx

# Projects database (powers the homepage + /projects)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Careers database (powers /careers). Share this DB with the integration above.
NOTION_CAREERS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The single Microsoft Form the Apply button links to.
# Leave blank to fall back to a mailto: link.
NEXT_PUBLIC_CAREERS_FORM_URL=https://forms.office.com/r/xxxxxxxx
